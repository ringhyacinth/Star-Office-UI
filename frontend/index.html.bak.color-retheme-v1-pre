    function applySceneFxQuality() {
        if (!cyberLayers) return;
        const low = isLowFxMode();
        if (Array.isArray(cyberLayers.rainDrops)) {
            cyberLayers.rainDrops.forEach(d => d.obj.setVisible(!low));
        }
        if (Array.isArray(cyberLayers.fogBands)) {
            cyberLayers.fogBands.forEach((fog, idx) => {
                fog.setVisible(!low || idx === 0);
                fog.setAlpha(low ? 0.06 : (0.08 + idx * 0.03));
            });
        }
        if (cyberLayers.scanPulse) {
            cyberLayers.scanPulse.setVisible(!low);
            cyberLayers.scanPulse.setAlpha(low ? 0.06 : 0.16);
        }
        if (Array.isArray(cyberLayers.neonLines)) {
            cyberLayers.neonLines.forEach(l => l.setAlpha(low ? 0.28 : 0.56));
        }
    }

    function applyPerformanceMode(mode, opts = {}) {
        const next = mode === 'low' ? 'low' : 'high';
        PERF_STATE.mode = next;
        document.body.classList.toggle('fx-low', next === 'low');
        if (opts.persist !== false) {
            try { localStorage.setItem('star-office-fx-mode', next); } catch(e) {}
        }
        updatePerfBadge(PERF_STATE.fpsBuffer.length ? (PERF_STATE.fpsBuffer.reduce((a,b)=>a+b,0)/PERF_STATE.fpsBuffer.length) : NaN);
        applySceneFxQuality();
    }

    function initPerformanceMode() {
        const btn = document.getElementById('fx-toggle');
        if (btn) {
            btn.addEventListener('click', () => {
                const next = isLowFxMode() ? 'high' : 'low';
                PERF_STATE.autoSwitched = false;
                PERF_STATE.lowFpsTicks = 0;
                applyPerformanceMode(next);
            });
        }
        let saved = '';
        try { saved = localStorage.getItem('star-office-fx-mode') || ''; } catch(e) {}
        const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        applyPerformanceMode(saved || (reduce ? 'low' : 'high'), { persist: false });
    }

    function perfMonitorTick(time) {
        if (!game || !game.loop) return;
        const fps = game.loop.actualFps || 60;
        PERF_STATE.fpsBuffer.push(fps);
        if (PERF_STATE.fpsBuffer.length > 20) PERF_STATE.fpsBuffer.shift();
        if (!PERF_STATE.lastCheck) PERF_STATE.lastCheck = time;
        if (time - PERF_STATE.lastCheck < 1200) return;

        const avg = PERF_STATE.fpsBuffer.reduce((a, b) => a + b, 0) / Math.max(PERF_STATE.fpsBuffer.length, 1);
        updatePerfBadge(avg);

        if (!isLowFxMode()) {
            if (avg < 40) PERF_STATE.lowFpsTicks += 1;
            else PERF_STATE.lowFpsTicks = Math.max(0, PERF_STATE.lowFpsTicks - 1);
            if (PERF_STATE.lowFpsTicks >= 4 && !PERF_STATE.autoSwitched) {
                PERF_STATE.autoSwitched = true;
                applyPerformanceMode('low');
            }
        }
        PERF_STATE.lastCheck = time;
    }

