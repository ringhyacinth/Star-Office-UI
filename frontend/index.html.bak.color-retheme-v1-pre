        const counts = {};
        for (const f of filters) counts[f.id] = 0;

        for (const [aid, rows] of Object.entries(logsMap || {})) {
            const arr = Array.isArray(rows) ? rows : [];
            counts.all += arr.length;
            if (LOG_V1_TASK_IDS.includes(aid)) counts[aid] = arr.length;
            counts.error += arr.filter(logV1IsError).length;
            counts.warning += arr.filter(logV1IsWarning).length;
            counts.done += arr.filter(logV1IsDone).length;
        }

        wrap.innerHTML = filters.map(f => {
            const active = logV1State.selectedFilter === f.id ? ' active' : '';
            const danger = f.danger ? ' danger' : '';
            const count = counts[f.id] || 0;
            return `<button class="log-chip${active}${danger}" data-log-filter="${f.id}">${escapeHtml(f.label)} <span style="opacity:.7">${count}</span></button>`;
        }).join('');

        wrap.querySelectorAll('[data-log-filter]').forEach(btn => {
