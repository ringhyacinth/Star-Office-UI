        e.preventDefault();
    });

    function onDragMove(e) {
        const dx = e.clientX - dragStartX;
        const dy = e.clientY - dragStartY;
        if (!isDragging && Math.abs(dx) + Math.abs(dy) > 5) isDragging = true;
        if (!isDragging) return;
        const parentRect = officeLeft.getBoundingClientRect();
        let nx = handleStartX + dx;
        let ny = handleStartY + dy;
        // 限制在 office-left 范围内
        nx = Math.max(0, Math.min(nx, parentRect.width - 58));
        ny = Math.max(0, Math.min(ny, parentRect.height - 58));
        scrollHandle.style.left = nx + 'px';
        scrollHandle.style.top = ny + 'px';
        scrollHandle.style.transform = 'none';
        // 如果面板打开，跟随移动
        if (scrollOpen) positionPanel();
    }

    function onDragEnd(e) {
        document.removeEventListener('mousemove', onDragMove);
        document.removeEventListener('mouseup', onDragEnd);
        if (!isDragging) {
            toggleScroll();
        }
        isDragging = false;
    }

    // 移除 onclick，用 mousedown/up 代替
    scrollHandle.removeAttribute('onclick');

    function positionPanel() {
        const body = document.getElementById('scroll-body');
        const parentRect = officeLeft.getBoundingClientRect();
        const hRect = scrollHandle.getBoundingClientRect();
        const hx = hRect.left - parentRect.left;
        const hy = hRect.top - parentRect.top;
        // 面板出现在图标右侧
        let panelLeft = hx + 60;
        let panelTop = hy - 120;
        // 边界修正
        if (panelLeft + 320 > parentRect.width) panelLeft = hx - 330;
        if (panelTop < 0) panelTop = 4;
        if (panelTop + 400 > parentRect.height) panelTop = parentRect.height - 404;
        body.style.left = panelLeft + 'px';
        body.style.top = panelTop + 'px';
        body.style.bottom = 'auto';
    }

    function toggleScroll() {
        const body = document.getElementById('scroll-body');
        scrollOpen = !scrollOpen;
        if (scrollOpen) {
            positionPanel();
            body.style.display = 'flex';
            // 游戏风展开：从中心缩放 + 透明度
            gsap.fromTo(body,
                { scaleY: 0, scaleX: 0.5, opacity: 0, transformOrigin: 'top left' },
                { scaleY: 1, scaleX: 1, opacity: 1, width: 320, duration: 0.4, ease: 'back.out(1.4)',
                  onComplete: () => { body.classList.add('open'); renderScrollTasks(); }
                }
            );
            // 图标发光
            scrollHandle.style.boxShadow = '0 0 20px rgba(255,215,0,0.6), 0 3px 10px rgba(0,0,0,0.5)';
        } else {
            body.classList.remove('open');
            gsap.to(body, {
                scaleY: 0, scaleX: 0.5, opacity: 0, duration: 0.25, ease: 'power2.in',
                onComplete: () => { body.style.display = 'none'; body.style.transform = ''; }
            });
            scrollHandle.style.boxShadow = '';
        }
    }

    const RARITY_MAP = {
        P0: { cls: 'rarity-legendary', label: '🟠传说' },
        P1: { cls: 'rarity-epic', label: '🟣史诗' },
        P2: { cls: 'rarity-rare', label: '🔵稀有' },
        P3: { cls: 'rarity-common', label: '⚪普通' },
    };

    function renderScrollTasks() {
        if (!scrollOpen) return;
        const doing = tasksData.filter(t => t.status === '进行中');
        const todo = tasksData.filter(t => t.status === '待办');
        const done = tasksData.filter(t => t.status === '已完成');

        // 进行中 — 战令卡
        const activeList = document.getElementById('scroll-active-list');
        if (!doing.length) {
            activeList.innerHTML = '<div style="text-align:center;color:#8b6914;font-size:10px;font-family:MedievalSharp,serif;padding:8px">⚔️ 暂无激战中的任务</div>';
        } else {
            activeList.innerHTML = doing.map(t => {
                const prog = parseFloat(t.progress || 0);
                const r = RARITY_MAP[(t.priority||'P1').toUpperCase()] || RARITY_MAP.P1;
                const hpPos = prog <= 30 ? '100% 100%' : prog <= 70 ? '50% 100%' : '0% 100%';
                return `<div class="war-card">
                    <div class="war-card-top">
                        <div class="war-card-avatar">${t.agent ? t.agent.slice(0,2) : '⚔️'}</div>
                        <div class="war-card-name">${t.name||t.task_id}</div>
                        <span class="war-card-rarity ${r.cls}">${r.label}</span>
                    </div>
                    <div class="war-card-hp">
                        <div class="war-card-hp-fill" style="width:${prog}%;background-position:${hpPos}"></div>
                        <div class="war-card-hp-ticks"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
                        <div class="war-card-hp-text">${prog}%</div>
                    </div>
                    <div class="war-card-agent">${t.agent||'未分配'}</div>
                </div>`;
            }).join('');
            // GSAP 入场动画
            gsap.fromTo('#scroll-active-list .war-card', { x: -30, opacity: 0 }, {
                x: 0, opacity: 1, duration: 0.4, stagger: 0.08, ease: 'back.out(1.5)'
            });
        }

        // 队列 — 悬赏令
        const queueList = document.getElementById('scroll-queue-list');
        if (!todo.length) {
            queueList.innerHTML = '<div style="text-align:center;color:#8b6914;font-size:10px;font-family:MedievalSharp,serif;padding:8px">📜 悬赏板空空如也</div>';
        } else {
            queueList.innerHTML = todo.map((t, i) => {
                const p = (t.priority||'P1').toUpperCase();
                const sealCls = 'seal-' + p.toLowerCase();
                const rot = (Math.random() * 4 - 2).toFixed(1);
                return `<div class="bounty-card" style="transform:rotate(${rot}deg)">
                    <div class="bounty-seal ${sealCls}">${p}</div>
                    <div class="bounty-name">${t.name||t.task_id}</div>
                    <div class="bounty-desc">${t.description||t.agent||''}</div>
                </div>`;
            }).join('');
        }

        // 已完成 — 燃烧卡
        const doneList = document.getElementById('scroll-done-list');
        const doneCount = document.getElementById('scroll-done-count');
        doneCount.textContent = `已完成 ${done.length} 项任务`;
        if (!done.length) {
            doneList.innerHTML = '<div style="text-align:center;color:#8b6914;font-size:10px;font-family:MedievalSharp,serif;padding:8px">📋 暂无已完成的任务</div>';
        } else {
            // 只显示最近5个
            const recent = done.slice(-5).reverse();
            doneList.innerHTML = recent.map((t, i) => {
                return `<div class="burn-card" data-idx="${i}">
                    <div class="burn-card-check">✅</div>
                    <div class="burn-card-name">${t.name||t.task_id}</div>
                </div>`;
            }).join('');
            // 给每个燃烧卡添加火星粒子
            document.querySelectorAll('.burn-card').forEach(card => {
                spawnEmbers(card);
            });
            // 入场动画
            gsap.fromTo('#scroll-done-list .burn-card', { y: -20, opacity: 0, scale: 1.1 }, {
                y: 0, opacity: 1, scale: 1, duration: 0.5, stagger: 0.1, ease: 'power2.out'
            });
        }
    }

    function spawnEmbers(card) {
        for (let i = 0; i < 3; i++) {
            const ember = document.createElement('div');
            ember.className = 'ember';
            ember.style.left = (10 + Math.random() * 80) + '%';
            ember.style.top = Math.random() * 100 + '%';
            card.appendChild(ember);
        }
    }
    // 每次 fetchTasks 后刷新卷轴：已合并到 fetchTasks()
    </script>
</body>
</html>
