    function createAgent(scene, id, data, index) {
        const color = data.color || '#78909C';
        const colorInt = hexToInt(color);
        createAgentTextures(scene, id, color);
        const stateInfo = STATES[data.state] || STATES.idle;
        const area = resolveArea(id, stateInfo);
        const totalAgentCount = Object.keys(agentsData).length || 15;
        const angle = (index / totalAgentCount) * Math.PI * 2 + index * 0.5;
        const sx = area.x + Math.cos(angle) * area.spread * 0.6;
        const sy = area.y + Math.sin(angle) * area.spread * 0.4;

        const shadow = scene.add.ellipse(sx + 2, sy + 18, 30, 10, 0x000000, 0.28).setDepth(8 + index);
        const aura = scene.add.circle(sx, sy - 3, 18, colorInt, 0.15)
            .setDepth(9 + index)
            .setBlendMode(Phaser.BlendModes.ADD);

        const sprite = scene.physics.add.sprite(sx, sy, id + '_open').setOrigin(0.5).setScale(1).setDepth(11 + index);
        sprite.body.setCircle(20, 6, 6);
        sprite.body.setImmovable(false);
        sprite.body.setBounce(0.3);

        const spark = scene.add.rectangle(sx + 8, sy - 11, 9, 2, 0x68ff9f, 0.86)
            .setDepth(12 + index)
            .setBlendMode(Phaser.BlendModes.ADD)
            .setAlpha(0.22);

        const emojiText = scene.add.text(sx, sy - 31, data.emoji || '🤖', {font:'24px sans-serif'}).setOrigin(0.5).setDepth(31 + index);
        const nameTag = scene.add.text(sx, sy + 32, data.name || id, {
            font:'bold 16px monospace',
            fill:color,
            stroke:'#000',
            strokeThickness:3
        }).setOrigin(0.5).setDepth(21 + index);

        agentSprites[id] = {
            sprite, nameTag, emojiText, shadow, aura, spark,
            color, colorInt,
            openKey:id + '_open', closedKey:id + '_closed', deadKey:id + '_dead',
            target:{x:sx,y:sy},
            lastBlink:Math.random()*3000,
            lastBubble:Math.random()*16000,
            bubble:null,
            index,
            isDead:false,
            deathBubble:null,
            phase: Math.random() * Math.PI * 2,
        };
    }

    // 分离力：防止小人重叠
    const SEPARATION_DIST = 46;  // 最小间距（像素）
    function separateAgents() {
        const ids = Object.keys(agentSprites);
        for (let i = 0; i < ids.length; i++) {
            for (let j = i + 1; j < ids.length; j++) {
                const a = agentSprites[ids[i]], b = agentSprites[ids[j]];
                const dx = a.sprite.x - b.sprite.x;
                const dy = a.sprite.y - b.sprite.y;
                const dist = Math.sqrt(dx*dx + dy*dy);
                if (dist < SEPARATION_DIST && dist > 0.1) {
                    const overlap = (SEPARATION_DIST - dist) * 0.5;
                    const nx = dx / dist, ny = dy / dist;
                    const push = overlap * 0.3;  // 柔和推力
                    a.sprite.x += nx * push;
                    a.sprite.y += ny * push;
                    b.sprite.x -= nx * push;
                    b.sprite.y -= ny * push;
                    // 同时调整目标点，避免反复拉回
                    a.target.x += nx * push * 0.5;
                    a.target.y += ny * push * 0.5;
                    b.target.x -= nx * push * 0.5;
                    b.target.y -= ny * push * 0.5;
                }
            }
        }
    }

    function pUpdate(time) {
        if (time - lastFetch > FETCH_INTERVAL) { fetchLive(); lastFetch = time; }
        animateCyberStreetLayers(time);
        animateDeptShopSigns(time);
        perfMonitorTick(time);

        for (const [id, a] of Object.entries(agentSprites)) {
            const data = agentsData[id] || { state:'idle' };
            const isDead = data.state === 'dead';
            const isWorking = WORKING_STATES.has(data.state);

            if (isDead && !a.isDead) {
                a.isDead = true;
                a.sprite.setTexture(a.deadKey);
                a.sprite.setAlpha(0.68);
                showDeathBubble(id, data.death_reason || data.detail || '未知原因');
            } else if (!isDead && a.isDead) {
                a.isDead = false;
                a.sprite.setTexture(a.openKey);
                a.sprite.setAlpha(1);
                removeDeathBubble(id);
            }

            if (!isDead && time - a.lastBlink > 2800 + Math.random() * 1400) {
                a.sprite.setTexture(a.closedKey);
                a.lastBlink = time;
                const sp = a.sprite, ok = a.openKey;
                setTimeout(() => { if (sp && sp.texture && !a.isDead) sp.setTexture(ok); }, 110 + Math.random() * 90);
            }
            if (time - a.lastBubble > 7600 + Math.random() * 5200) {
                showBubble(id, data.state);
                a.lastBubble = time;
            }

            const dx = a.target.x - a.sprite.x;
            const dy = a.target.y - a.sprite.y;
            const moving = Math.abs(dx) > 2 || Math.abs(dy) > 2;

            if (isDead) {
                a.sprite.y += Math.sin(time / 1900 + a.index) * 0.08;
                a.sprite.setAngle(Math.sin(time / 2800 + a.index) * 1.3);
            } else {
                if (Math.abs(dx) > 2) a.sprite.x += Math.sign(dx) * 0.7;
                if (Math.abs(dy) > 2) a.sprite.y += Math.sign(dy) * 0.7;
                if (moving) {
                    a.sprite.y += Math.sin(time / 120 + a.index * 0.7) * 0.3;
                    a.sprite.setAngle(Math.sin(time / 100 + a.index) * 2);
                } else {
                    a.sprite.setAngle(0);
                    a.sprite.y += Math.sin(time / 800 + a.index * 0.5) * 0.15;
                }
            }

            if (!isDead && Math.random() < 0.002) {
                const stateInfo = STATES[data.state] || STATES.idle;
                const area = resolveArea(id, stateInfo);
                const totalAC = Object.keys(agentSprites).length || 15;
                const ang = (a.index / totalAC) * Math.PI * 2 + (Math.random() - 0.5) * 2.0;
                const r = area.spread * (isWorking ? 0.35 + Math.random() * 0.45 : 0.15 + Math.random() * 0.3);
                a.target.x = Math.max(20, Math.min(1580, area.x + Math.cos(ang) * r));
                a.target.y = Math.max(150, Math.min(630, area.y + Math.sin(ang) * r * 0.6));
            }

            const pulse = Math.abs(Math.sin(time / (isLowFxMode() ? 980 : 560) + a.phase));
            if (a.shadow) {
                a.shadow.setPosition(a.sprite.x + 2, a.sprite.y + 19);
                a.shadow.setScale(1 + (moving ? 0.06 : 0), 1 + (moving ? 0.08 : 0));
                a.shadow.setAlpha(isDead ? 0.16 : (0.2 + pulse * 0.08));
            }
            if (a.aura) {
                a.aura.setPosition(a.sprite.x, a.sprite.y - 2);
                a.aura.setScale(1 + pulse * (isLowFxMode() ? 0.06 : 0.13));
                if (isDead) a.aura.setAlpha(0.04);
                else if (isWorking) a.aura.setAlpha(0.16 + pulse * 0.22);
                else a.aura.setAlpha(0.08 + pulse * 0.12);
            }
            if (a.spark) {
                a.spark.setPosition(a.sprite.x + 8 + Math.sin(time / 220 + a.phase) * 4, a.sprite.y - 10);
                a.spark.setAlpha(isDead ? 0 : (isWorking ? 0.26 + pulse * 0.5 : 0.1 + pulse * 0.14));
                a.spark.width = isWorking ? (8 + pulse * 8) : (7 + pulse * 3);
            }

            a.nameTag.setPosition(a.sprite.x, a.sprite.y + 31);
            a.emojiText.setPosition(a.sprite.x, a.sprite.y - 31);
            if (a.deathBubble) updateDeathBubblePos(id);
        }

        separateAgents();
        if ((time % 500) < 16) updateDeptShopSigns();
    }

    function showBubble(agentId, state) {
        const a = agentSprites[agentId]; if (!a) return;
        if (a.bubble) { a.bubble.destroy(); a.bubble = null; }
        const texts = BUBBLE_TEXTS[state]||BUBBLE_TEXTS.idle;
        const text = texts[Math.floor(Math.random()*texts.length)];
        const bg = game.add.rectangle(a.sprite.x, a.sprite.y-50, text.length*11+20, 24, 0xffffff, 0.92);
        bg.setStrokeStyle(1, 0x999999).setDepth(90);
        const txt = game.add.text(a.sprite.x, a.sprite.y-50, text, {font:'14px monospace',fill:'#333'}).setOrigin(0.5).setDepth(91);
        a.bubble = game.add.container(0, 0, [bg, txt]).setDepth(90);
        setTimeout(() => { if(a.bubble){a.bubble.destroy();a.bubble=null;} }, 2200);
    }

    // ============ 死亡原因悬浮气泡（画布顶部） ============
    let deathBubbleSlots = {}; // agentId -> slot index
    let nextDeathSlot = 0;

    function showDeathBubble(agentId, reason) {
        const a = agentSprites[agentId]; if (!a || !game) return;
        removeDeathBubble(agentId);
        const data = agentsData[agentId] || {};
        const name = data.name || agentId;
        const emoji = data.emoji || '🤖';
        const displayText = `💀 ${emoji}${name}: ${reason || '未知错误'}`;
        // 分配顶部槽位
        const slot = nextDeathSlot++;
        deathBubbleSlots[agentId] = slot;
        const slotY = 16 + slot * 28;
        const slotX = 800; // 画布中心
        // 像素风格气泡背景
        const textLen = displayText.length;
        const bgW = Math.min(textLen * 12 + 40, 900);
        const bg = game.add.rectangle(slotX, slotY, bgW, 28, 0x1a0000, 0.88);
        bg.setStrokeStyle(2, 0xff0000).setDepth(200);
        const txt = game.add.text(slotX, slotY, displayText, {
            font: '15px monospace', fill: '#ff4444', stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(201);
        // 闪烁的骷髅图标
        const skull = game.add.text(slotX - bgW/2 + 14, slotY, '☠️', {font:'18px sans-serif'}).setOrigin(0.5).setDepth(202);
        // 脉冲动画
        game.tweens.add({ targets: bg, alpha: {from:0.85, to:0.5}, duration: 1200, yoyo: true, repeat: -1 });
        game.tweens.add({ targets: skull, scaleX: {from:1, to:1.3}, scaleY: {from:1, to:1.3}, duration: 800, yoyo: true, repeat: -1 });
        a.deathBubble = game.add.container(0, 0, [bg, txt, skull]).setDepth(200);
    }

    function removeDeathBubble(agentId) {
        const a = agentSprites[agentId]; if (!a) return;
        if (a.deathBubble) {
            a.deathBubble.destroy();
            a.deathBubble = null;
        }
        if (agentId in deathBubbleSlots) {
            delete deathBubbleSlots[agentId];
            // 重新排列槽位
            repackDeathSlots();
        }
    }

    function repackDeathSlots() {
        let idx = 0;
        for (const aid of Object.keys(deathBubbleSlots)) {
            deathBubbleSlots[aid] = idx++;
            const a = agentSprites[aid];
            if (a && a.deathBubble) {
                const slotY = 16 + deathBubbleSlots[aid] * 28;
                a.deathBubble.each(child => { child.y = slotY; });
            }
        }
        nextDeathSlot = idx;
    }

    function updateDeathBubblePos(agentId) {
        // 死亡气泡固定在画布顶部，不跟随角色移动
        // 位置已在 showDeathBubble 中设定，无需更新
    }
    </script>
    <script>
