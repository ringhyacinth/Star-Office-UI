    function escapeHtml(v) {
        return safeText(v)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }
    function escapeAttr(v) {
        return escapeHtml(v).replace(/\n/g, ' ');
    }
    function safeColor(v, fallback) {
        const s = safeText(v).trim();
        return /^#[0-9a-fA-F]{3,8}$/.test(s) ? s : fallback;
    }
    function priorityClass(p) {
