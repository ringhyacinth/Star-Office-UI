        for (let y = 0; y < 8; y++) {
            const yy = 452 + y * 24;
            ground.lineStyle(1, y % 2 ? 0x22395d : 0x304f7e, 0.18 - y * 0.014);
            ground.lineBetween(0, yy, 1600, yy);
        }

        const roadNeon = scene.add.graphics().setDepth(9);
        roadNeon.lineStyle(2, 0xff4fb9, 0.24);
        roadNeon.lineBetween(0, 484, 1600, 484);
        roadNeon.lineStyle(1, 0x39d5ff, 0.24);
        roadNeon.lineBetween(0, 498, 1600, 498);
        roadNeon.lineStyle(1, 0x8f7bff, 0.2);
        roadNeon.lineBetween(0, 512, 1600, 512);

        const sweep = scene.add.rectangle(800, 452, 1800, 10, 0x39d5ff, 0.09).setDepth(10);
        const scanPulse = scene.add.rectangle(800, 470, 1600, 36, 0x66b6ff, 0.08)
            .setDepth(11)
            .setBlendMode(Phaser.BlendModes.ADD);

        const rainDrops = [];
