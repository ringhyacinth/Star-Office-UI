    function logV1IsError(log) {
        const txt = safeText(log && log.text).toLowerCase();
        const stop = safeText(log && log.stop).toLowerCase();
        return stop === 'error' || /❌|error|fatal|exception|traceback|失败|异常|崩溃|阵亡|dead/.test(txt);
    }
    function logV1IsWarning(log) {
        const txt = safeText(log && log.text).toLowerCase();
        if (logV1IsError(log)) return false;
        return /⚠️|warn|warning|重试|retry|timeout|超时|429|限流|阻塞|拥塞|降级/.test(txt);
    }
    function logV1IsDone(log) {
        const txt = safeText(log && log.text).toLowerCase();
        const stop = safeText(log && log.stop).toLowerCase();
        return stop === 'stop' || /完成|已完成|done|完成了|上线成功|lgtm/.test(txt);
    }

    function logV1FilterLine(log, filterId) {
        if (filterId === 'error') return logV1IsError(log);
        if (filterId === 'warning') return logV1IsWarning(log);
        if (filterId === 'done') return logV1IsDone(log);
        return true;
    }

    function logV1Fingerprint(log) {
        const row = log && typeof log === 'object' ? log : {};
        const msgId = safeText(row.id || row.log_id || row.message_id || row.seq || '').trim();
        if (msgId) return `id:${msgId}`;
        const ts = safeText(row.ts).trim();
        const role = safeText(row.role).trim().toLowerCase();
        const stop = safeText(row.stop).trim().toLowerCase();
        const text = safeText(row.text).replace(/\s+/g, ' ').trim().slice(0, 700);
        return `${ts}␟${role}␟${stop}␟${text}`;
    }

    function logV1DedupeLogsMap(logsMap) {
        const src = logsMap && typeof logsMap === 'object' ? logsMap : {};
        const deduped = {};
        const perAgent = {};
        let sourceTotal = 0;
        let uniqueTotal = 0;

        for (const [aid, rows] of Object.entries(src)) {
            const arr = Array.isArray(rows) ? rows : [];
            sourceTotal += arr.length;

            const seen = new Set();
            const nextRows = [];
            for (const raw of arr) {
                const row = raw && typeof raw === 'object' ? raw : { text: safeText(raw) };
                const fp = logV1Fingerprint(row);
                if (seen.has(fp)) continue;
                seen.add(fp);
                nextRows.push(row);
            }

            uniqueTotal += nextRows.length;
            deduped[aid] = nextRows;
            perAgent[aid] = {
                source: arr.length,
                unique: nextRows.length,
                dropped: arr.length - nextRows.length,
            };
        }

        return {
            logs: deduped,
            stats: {
                sourceTotal,
                uniqueTotal,
                droppedTotal: Math.max(0, sourceTotal - uniqueTotal),
                perAgent,
            },
        };
    }

    function logV1UpdateDedupBadge(stats) {
        const el = document.getElementById('logv1-dedup');
        if (!el) return;
        const source = Number(stats && stats.sourceTotal) || 0;
        const unique = Number(stats && stats.uniqueTotal) || 0;
        const dropped = Math.max(0, source - unique);
        el.textContent = `${unique} / ${source}${dropped > 0 ? `（-${dropped}）` : ''}`;
        el.className = `value ${dropped > 0 ? 'warn' : 'ok'}`;
    }

    function logV1UpdateOverview(agents, tasks, logs) {
        const agentList = Object.values(agents || {});
        const blocked = (tasks || []).filter(t => /阻塞|blocked/i.test(safeText(t && t.status))).length;

        let errCount = 0;
        for (const a of agentList) {
            const s = normalizeState(a && a.state);
            if (s === 'error' || s === 'dead') errCount += 1;
        }
        for (const rows of Object.values(logs || {})) {
            if (!Array.isArray(rows)) continue;
            errCount += rows.filter(logV1IsError).length;
        }

        const beEl = document.getElementById('logv1-block-err');
        if (beEl) {
            beEl.textContent = `阻塞 ${blocked} / 错误 ${errCount}`;
            beEl.className = `value ${errCount > 0 ? 'err' : (blocked > 0 ? 'warn' : 'ok')}`;
        }
        logV1UpdateDedupBadge(logV1State.dedupStats);
    }

    function logV1BuildChips(logsMap, agents) {
        const wrap = document.getElementById('log-filter-chips');
        if (!wrap) return;

        const filters = [
            ...LOG_V1_BASE_FILTERS,
            ...LOG_V1_TASK_IDS.map(id => ({ id, label: id }))
