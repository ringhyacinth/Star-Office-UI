        deploying:   { name:'部署', area:'work', color:'#ff5722' },
        meeting:     { name:'开会', area:'work', color:'#673ab7' }
    };
    const WORKING_STATES = new Set(['writing','researching','executing','reviewing','testing','deploying','meeting']);
    // 每个部门有 work(办公) 和 rest(休闲) 两个子区域
    const DEPT_ZONES = {
        info: { work:{x:151,y:258,spread:110}, rest:{x:391,y:258,spread:70} },
        dev:  { work:{x:651,y:258,spread:110}, rest:{x:891,y:258,spread:70} },
        test: { work:{x:1151,y:258,spread:110}, rest:{x:1391,y:258,spread:70} },
        fin:  { work:{x:151,y:508,spread:110}, rest:{x:391,y:508,spread:70} },
        plan: { work:{x:651,y:508,spread:110}, rest:{x:891,y:508,spread:70} },
        cmd:  { work:{x:1151,y:508,spread:110}, rest:{x:1391,y:508,spread:70} },
    };
    const DEPT_META = {
        info: { name: '情报室', icon: '📰', color: 0x39d5ff },
        dev:  { name: '开发区', icon: '💻', color: 0x68ff9f },
        test: { name: '测试区', icon: '🧪', color: 0x8f7bff },
        fin:  { name: '金融区', icon: '💰', color: 0xffd45a },
        plan: { name: '策划产品', icon: '📋', color: 0xff4fb9 },
        cmd:  { name: '指挥中心', icon: '🗡️', color: 0x6ec8ff },
    };
    // 每个 agent 的归属部门
    const AGENT_HOME = {
        main:  'cmd',    // 宗主 → 指挥中心
        task1: 'dev',    // 拉磨驴 → 开发区
        task2: 'dev',    // 上等马 → 开发区
        task3: 'dev',    // 看门狗 → 开发区
        task4: 'plan',   // 领头羊 → 策划产品
        task5: 'info',   // 出头鸟 → 情报室
        task6: 'fin',    // 铁公鸡 → 金融区
        task7: 'cmd',    // 笑面虎 → 指挥中心
        task8: 'plan',   // 妙法天尊 → 策划产品
        task9: 'test',   // 天地一子 → 测试区
        task10:'info',   // 探宝鼠 → 情报室
        task11:'test',   // 知更鸟 → 测试区
        task12:'fin',    // 涨停板 → 金融区
        task13:'cmd',    // 哲学猫 → 指挥中心
        task14:'info',   // 旅行者 → 情报室
        task15:'info',   // 派蒙 → 情报室
        task16:'dev',    // 大根骑士 → 开发区
    };
    // idle/error/syncing → 休闲区, 工作状态 → 办公区
