            .setBlendMode(Phaser.BlendModes.ADD);

        const windows = [];
        const neonLines = [];
        const parallaxNodes = [];

        const farCount = low ? 14 : 22;
        for (let i = 0; i < farCount; i++) {
            const x = 40 + i * (1600 / farCount) + (i % 2 ? 10 : -8);
            const h = 58 + (i % 5) * 18;
