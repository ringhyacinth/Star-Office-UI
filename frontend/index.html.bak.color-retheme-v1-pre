    function createIsoBuilding(scene, opts) {
        const {
            x, groundY, width, height, depth,
            front, side, top, neon,
            alpha = 1, z = 2,
            rows = 4, cols = 3,
        } = opts;
        const wrap = scene.add.container(x, groundY);
        const shadow = scene.add.ellipse(depth * 0.32, 5, width + depth * 1.7, 13, 0x000000, 0.2 * alpha);

        const topFace = scene.add.polygon(0, 0, [
            -width / 2, -height,
            width / 2, -height,
            width / 2 + depth, -height - depth * 0.55,
            -width / 2 + depth, -height - depth * 0.55,
        ], top, 0.96 * alpha);
        const frontFace = scene.add.rectangle(0, -height / 2, width, height, front, 0.96 * alpha);
        const sideFace = scene.add.polygon(0, 0, [
            width / 2, -height,
            width / 2 + depth, -height - depth * 0.55,
            width / 2 + depth, -depth * 0.55,
            width / 2, 0,
        ], side, 0.92 * alpha);

        const edge = scene.add.graphics();
        edge.lineStyle(1, 0xc8e8ff, 0.3 * alpha);
        edge.strokeLineShape(new Phaser.Geom.Line(-width / 2, -height, width / 2, -height));
        edge.strokeLineShape(new Phaser.Geom.Line(width / 2, -height, width / 2 + depth, -height - depth * 0.55));
        edge.strokeLineShape(new Phaser.Geom.Line(width / 2 + depth, -height - depth * 0.55, width / 2 + depth, -depth * 0.55));

        const neonLine = scene.add.rectangle(0, -height + 9, width * 0.72, 2, neon, 0.56 * alpha)
            .setBlendMode(Phaser.BlendModes.ADD);

        const windows = [];
        const rowH = Math.max(10, (height - 20) / rows);
        const colW = Math.max(10, (width - 14) / cols);
        for (let r = 0; r < rows; r++) {
            for (let c = 0; c < cols; c++) {
                const wx = -width / 2 + 8 + c * colW + (c % 2 ? 1 : 0);
                const wy = -height + 12 + r * rowH;
                const tint = (r + c) % 3 === 0 ? neon : (r % 2 ? 0x8f7bff : 0x39d5ff);
                const w = scene.add.rectangle(wx, wy, 4, 6, tint, 0.2 + Math.random() * 0.4)
                    .setOrigin(0, 0);
                windows.push(w);
            }
        }

        wrap.add([shadow, topFace, frontFace, sideFace, edge, neonLine, ...windows]);
        wrap.setDepth(z);
        return { wrap, windows, neonLine, baseX: x };
    }

    function createCyberStreetLayers(scene) {
        const low = isLowFxMode();
