    function animateCyberStreetLayers(time) {
        if (!cyberLayers) return;
        const low = isLowFxMode();
        const t = time || 0;

        if (Array.isArray(cyberLayers.windows)) {
            const step = low ? 3 : 1;
            for (let i = 0; i < cyberLayers.windows.length; i += step) {
                const w = cyberLayers.windows[i];
                if (!w) continue;
                w.alpha = (low ? 0.18 : 0.24) + Math.abs(Math.sin((t / 900) + i * 0.63)) * (low ? 0.22 : 0.5);
            }
        }
        if (Array.isArray(cyberLayers.parallaxNodes)) {
            const mul = low ? 0.35 : 1;
            cyberLayers.parallaxNodes.forEach((n, i) => {
                if (!n || !n.node) return;
                n.node.x = n.baseX + Math.sin((t / n.speed) + i * 0.37) * n.amp * mul;
            });
        }
        if (Array.isArray(cyberLayers.neonLines)) {
            cyberLayers.neonLines.forEach((line, i) => {
                if (!line) return;
                line.alpha = (low ? 0.18 : 0.34) + Math.abs(Math.sin(t / 680 + i * 0.41)) * (low ? 0.14 : 0.4);
            });
        }
        if (cyberLayers.sweep) {
            cyberLayers.sweep.x = 800 + Math.sin(t / 1300) * 220;
            cyberLayers.sweep.alpha = (low ? 0.03 : 0.06) + Math.abs(Math.sin(t / 700)) * (low ? 0.06 : 0.12);
        }
        if (cyberLayers.scanPulse) {
            cyberLayers.scanPulse.alpha = (low ? 0.04 : 0.08) + Math.abs(Math.sin(t / 780)) * (low ? 0.05 : 0.12);
        }
        if (!low && Array.isArray(cyberLayers.rainDrops)) {
            cyberLayers.rainDrops.forEach((drop, i) => {
                if (!drop || !drop.obj || !drop.obj.visible) return;
                drop.obj.y += drop.speed;
                drop.obj.x -= drop.drift;
                if (drop.obj.y > 662 || drop.obj.x < -8) {
                    drop.obj.y = -8 - Math.random() * 24;
                    drop.obj.x = 1600 + Math.random() * 100;
                }
                if (i % 5 === 0) {
                    drop.obj.alpha = 0.1 + Math.abs(Math.sin((t / 340) + i)) * 0.22;
                }
            });
        }
        if (Array.isArray(cyberLayers.fogBands)) {
            cyberLayers.fogBands.forEach((fog, i) => {
                if (!fog || !fog.visible) return;
                fog.x += Math.sin((t / (2400 + i * 640)) + i) * (low ? 0.015 : 0.05);
                fog.y += Math.cos((t / (2800 + i * 720)) + i) * (low ? 0.006 : 0.02);
            });
        }
    }

