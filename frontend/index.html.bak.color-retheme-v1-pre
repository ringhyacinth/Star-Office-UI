    // ============ 日志面板 ============
    function renderLogs(logs, agents, opts = {}) {
        const container = document.getElementById('log-panel');
        if (!container) return;

        const force = !!opts.force;
        const sourceLogsMap = logs && typeof logs === 'object' ? logs : {};
        const agentMap = agents && typeof agents === 'object' ? agents : {};
        const dedupResult = logV1DedupeLogsMap(sourceLogsMap);
        const logsMap = dedupResult.logs;

        logV1State.rawLogs = logsMap;
        logV1State.rawAgents = agentMap;
        logV1State.dedupStats = dedupResult.stats;

        logV1BuildChips(logsMap, agentMap);
        logV1UpdateOverview(agentMap, tasksData, logsMap);
        logV1RefreshActionBtnState();

        if (logV1State.pauseScroll && !force) {
            return;
        }

        const prevScrollTop = container.scrollTop;

        // 按最新日志时间排序：有新日志的排前面
        const sortedAids = Object.keys(agentMap).sort((a, b) => {
            const la = Array.isArray(logsMap[a]) ? logsMap[a] : [];
            const lb = Array.isArray(logsMap[b]) ? logsMap[b] : [];
            const ta = la.length ? safeText(la[la.length - 1].ts) : '';
            const tb = lb.length ? safeText(lb[lb.length - 1].ts) : '';
            return tb.localeCompare(ta);
        });

        const selected = logV1State.selectedFilter || 'all';
        const onlyException = !!logV1State.onlyException;

        let html = '';
        for (const aid of sortedAids) {
            if (selected.startsWith('task') && aid !== selected) continue;

            const rawAgent = agentMap[aid];
            const a = rawAgent && typeof rawAgent === 'object' ? rawAgent : {};
            const rawLogs = logsMap[aid];
            const agentLogs = Array.isArray(rawLogs) ? rawLogs : [];

            const s = normalizeState(a.state) || 'idle';
            const si = STATES[s] || STATES.idle;
            const cfgModel = safeText(a.model);
            const shortModel = cfgModel ? cfgModel.split('/').pop() : '';
            const textColor = safeColor(a.color, '#ccc');

            const filteredLogs = agentLogs.filter(log => {
                const basic = logV1FilterLine(log, selected);
                const ex = !onlyException || logV1IsError(log) || logV1IsWarning(log);
                return basic && ex;
            });

            if (selected === 'error' && !(s === 'error' || s === 'dead') && !filteredLogs.length) continue;
            if (selected === 'warning' && !filteredLogs.length) continue;
            if (selected === 'done' && !filteredLogs.length) continue;
            if (selected === 'all' && onlyException && !filteredLogs.length && !(s === 'error' || s === 'dead')) continue;

            let sectionClass = 'log-section';
            if (s === 'error' || s === 'dead' || filteredLogs.some(logV1IsError)) sectionClass += ' has-error';
            else if (WORKING_STATES.has(s)) sectionClass += ' is-active';

            html += `<div class="${sectionClass}"><div class="log-header">`;
            html += `<span>${escapeHtml(a.emoji || '🤖')}</span><span class="a-name" style="color:${textColor}">${escapeHtml(a.name || aid)}</span>`;
            if (shortModel) html += `<span class="a-model">${escapeHtml(shortModel)}</span>`;
            html += `</div>`;

            if (!filteredLogs.length) {
                html += `<div class="log-line"><span class="lt"></span><span class="lr">-</span><span class="lx" style="color:#4a4a61">当前筛选下无日志</span></div>`;
            } else {
                for (const rawLog of filteredLogs) {
                    const log = rawLog && typeof rawLog === 'object' ? rawLog : {};
                    const role = safeText(log.role);
                    const stop = safeText(log.stop);
                    let rc = 'r-system', icon = '⚙️';
                    if (role === 'user') { rc = 'r-user'; icon = '👤'; }
                    else if (role === 'assistant') {
                        if (stop === 'error') { rc = 'r-error'; icon = '❌'; }
                        else { rc = 'r-assistant'; icon = '🤖'; }
                    } else if (role === 'toolResult') { rc = 'r-tool'; icon = '🔧'; }

                    if (logV1IsError(log)) { rc = 'r-error'; icon = '❌'; }
                    else if (logV1IsWarning(log) && rc === 'r-system') { icon = '⚠️'; }
                    else if (logV1IsDone(log) && rc !== 'r-error') { icon = '✅'; }

                    const ts = utcToBJ(safeText(log.ts), true);
                    const lineText = safeText(log.text);
                    html += `<div class="log-line ${rc}"><span class="lt">${escapeHtml(ts)}</span><span class="lr">${icon}</span><span class="lx" title="${escapeAttr(lineText)}">${escapeHtml(lineText)}</span></div>`;
                }
            }
            html += `</div>`;
        }

        container.innerHTML = html || '<div class="empty-state" style="padding:24px 0;font-size:11px">当前筛选暂无日志</div>';

        if (logV1State.pauseScroll) {
            container.scrollTop = prevScrollTop;
        } else if (force) {
            container.scrollTop = prevScrollTop;
        }
    }

