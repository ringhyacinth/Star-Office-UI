                .setDepth(24 + (i % 2));
            rainDrops.push({ obj: d, speed: 2.6 + Math.random() * 2.8, drift: 0.25 + Math.random() * 0.45 });
        }

        const fogBands = [
            scene.add.ellipse(400, 542, 520, 92, 0x8ab4ff, 0.08).setDepth(23),
            scene.add.ellipse(1120, 556, 620, 106, 0xb5d1ff, 0.11).setDepth(23),
            scene.add.ellipse(830, 575, 760, 118, 0x7aa8ff, 0.08).setDepth(23),
        ];

        farBand.setDepth(1);
        hazeBack.setDepth(2);
        ground.setDepth(8);

        cyberLayers = { windows, sweep, scanPulse, parallaxNodes, neonLines, rainDrops, fogBands };
        sceneFx = cyberLayers;
