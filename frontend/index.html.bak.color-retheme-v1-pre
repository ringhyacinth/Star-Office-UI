    // ============ 全局数据 ============
    let agentsData = {}, tasksData = [], agentSprites = {}, game = null;
    let cyberLayers = null, deptSigns = {}, prevTaskStatusMap = {}, sceneFx = null;
    const PERF_STATE = {
        mode: 'high',
        lowFpsTicks: 0,
        fpsBuffer: [],
        lastCheck: 0,
        autoSwitched: false,
