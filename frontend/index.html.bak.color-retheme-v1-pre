<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI 特工队总部 — 任务大厅</title>
    <script src="https://cdn.jsdelivr.net/npm/phaser@3.80.1/dist/phaser.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=MedievalSharp&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            /* ===== 赛博像素主题 Token（V1） ===== */
            --cyber-bg-0: #060912;
            --cyber-bg-1: #0a1020;
            --cyber-bg-2: #101931;
            --cyber-surface-1: #121a2f;
            --cyber-surface-2: #17213d;
            --cyber-border: #2a3555;
            --cyber-neon-cyan: #39d5ff;
            --cyber-neon-pink: #ff4fb9;
            --cyber-neon-purple: #8f7bff;
            --cyber-neon-green: #68ff9f;
            --cyber-warning: #ffd45a;
            --cyber-danger: #ff5f70;
            --cyber-text-main: #d4def5;
            --cyber-text-dim: #7f8aac;

            /* 兼容旧变量，避免破坏现有功能 */
            --bg-primary: var(--cyber-bg-0);
            --bg-secondary: var(--cyber-bg-1);
            --bg-card: var(--cyber-surface-1);
            --bg-hover: var(--cyber-surface-2);
            --border: var(--cyber-border);
            --accent: var(--cyber-neon-pink);
            --accent2: var(--cyber-neon-purple);
            --green: var(--cyber-neon-green);
            --yellow: var(--cyber-warning);
            --red: var(--cyber-danger);
            --blue: var(--cyber-neon-cyan);
            --text: var(--cyber-text-main);
            --text-dim: var(--cyber-text-dim);
            --text-bright: #ffffff;
        }
        body {
            background:
                radial-gradient(120% 140% at 0% 0%, rgba(57,213,255,0.12), transparent 48%),
                radial-gradient(100% 120% at 100% 100%, rgba(255,79,185,0.1), transparent 52%),
                linear-gradient(180deg, var(--cyber-bg-2), var(--cyber-bg-0));
            font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
            color: var(--text);
            overflow: hidden;
            height: 100vh;
        }
        /* ===== 顶部导航 ===== */
        #top-bar {
            height: 42px;
            background: linear-gradient(90deg, rgba(14,26,48,0.96), rgba(12,20,40,0.96));
            border-bottom: 1px solid var(--border);
            box-shadow: 0 2px 16px rgba(57,213,255,0.08), inset 0 -1px 0 rgba(255,79,185,0.12);
            display: flex;
            align-items: center;
            padding: 0 16px;
            gap: 4px;
            user-select: none;
        }
        #top-bar .brand {
            display: flex; align-items: center; gap: 8px;
            margin-right: 20px;
        }
        #top-bar .brand .logo { font-size: 18px; }
        #top-bar .brand .title {
            font-size: 14px; color: var(--accent); font-weight: 700;
            letter-spacing: 1px;
        }
        .nav-tab {
            padding: 8px 16px; font-size: 12px; color: var(--text-dim);
            cursor: pointer; border-bottom: 2px solid transparent;
            transition: all 0.2s; line-height: 24px; border-radius: 4px 4px 0 0;
        }
        .nav-tab:hover { color: #aaa; background: rgba(255,255,255,0.03); }
        .nav-tab.active { color: var(--accent); border-bottom-color: var(--accent); background: rgba(233,69,96,0.06); }
        .nav-tab .icon { margin-right: 4px; }
        .nav-link {
            padding: 8px 16px; font-size: 12px; color: var(--text-dim);
            cursor: pointer; text-decoration: none; line-height: 24px;
            border-radius: 4px 4px 0 0; transition: all 0.2s;
        }
        .nav-link:hover { color: var(--accent2); background: rgba(108,92,231,0.08); }
        .nav-link .icon { margin-right: 4px; }
        #top-bar .right-info {
            margin-left: auto; display: flex; align-items: center; gap: 10px;
            flex: 0 0 auto;
            padding: 3px 8px;
            border-radius: 10px;
            background: linear-gradient(90deg, rgba(12,20,38,0.62), rgba(12,20,38,0.35));
            border: 1px solid rgba(57,213,255,0.12);
            min-width: 0;
        }
        .live-dot {
            width: 7px; height: 7px; border-radius: 50%;
            background: var(--green); animation: pulse 1.5s infinite;
            box-shadow: 0 0 6px var(--green);
        }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
        .stat-badge {
            font-size: 10px; padding: 2px 8px; border-radius: 10px;
            background: rgba(255,255,255,0.05); border: 1px solid var(--border);
        }
        .stat-badge .num { color: var(--accent); font-weight: 700; }
        .clock-display { font-size: 11px; color: var(--text-dim); font-family: 'Courier New', monospace; min-width: 160px; }
        .fx-toggle {
            border: 1px solid rgba(57,213,255,0.35);
            background: rgba(57,213,255,0.1);
            color: #d5f2ff;
            border-radius: 12px;
            padding: 2px 10px;
            font-size: 10px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .fx-toggle:hover { border-color: rgba(104,255,159,0.6); color: #fff; background: rgba(104,255,159,0.12); }
        .fx-toggle.low {
            border-color: rgba(255,212,90,0.55);
            background: rgba(255,212,90,0.14);
            color: #ffe8a2;
        }
        #fps-indicator.low {
            border-color: rgba(255,212,90,0.42);
            color: #ffd45a;
        }
</style>
    <style>
        /* ===== 主内容区 ===== */
        #main-content { height: calc(100vh - 42px); position: relative; }
        .view-panel { display:none; width:100%; height:100%; position:absolute; top:0; left:0; }
        .view-panel.active { display:flex; }
        /* 办公室视图始终保持在 DOM 中，避免 Phaser canvas 被销毁 */
        #view-office { display:flex !important; }
        #view-office:not(.active) { visibility:hidden; z-index:-1; pointer-events:none; }

        /* ===== 办公室视图 ===== */
        #view-office { flex-direction: row; }
        #office-left {
            flex: 1 1 60%; display: flex; flex-direction: column;
            border-right: 1px solid var(--border); min-width: 0;
        }
        #game-container {
            position: relative;
            border-bottom: 1px solid var(--border); image-rendering: pixelated;
            width: 100%; overflow: hidden; max-height: 45vh;
            background:
                radial-gradient(120% 100% at 50% 0%, rgba(78,132,255,0.16), transparent 52%),
                linear-gradient(180deg, rgba(18,28,52,0.96) 0%, rgba(8,12,24,0.95) 38%, rgba(6,9,18,0.96) 100%);
            box-shadow:
                inset 0 -12px 30px rgba(0,0,0,0.35),
                inset 0 1px 0 rgba(255,255,255,0.06),
                0 10px 24px rgba(0,0,0,0.25);
        }
        #game-container::before,
        #game-container::after {
            content: '';
            position: absolute;
            inset: 0;
            pointer-events: none;
        }
        #game-container::before {
            background:
                linear-gradient(rgba(0,0,0,0) 50%, rgba(6,12,26,0.16) 50%),
                linear-gradient(90deg, transparent 96%, rgba(57,213,255,0.05) 100%);
            background-size: 100% 4px, 14px 100%;
            opacity: 0.42;
            mix-blend-mode: screen;
            animation: scanlineDrift 10s linear infinite;
        }
        #game-container::after {
            background:
                radial-gradient(120% 100% at 50% 120%, rgba(255,79,185,0.18), transparent 45%),
                linear-gradient(180deg, transparent 72%, rgba(57,213,255,0.08) 100%);
        }
        @keyframes scanlineDrift {
            0% { background-position: 0 0, 0 0; }
            100% { background-position: 0 160px, 14px 0; }
        }
        #v2-fx-overlays {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 40;
            overflow: hidden;
        }
        .v2-overlay-rain,
        .v2-overlay-fog,
        .v2-overlay-scan,
        .v2-overlay-haze {
            position: absolute;
            inset: 0;
        }
        .v2-overlay-rain {
            background-image: linear-gradient(180deg, rgba(180,220,255,0.00) 0%, rgba(180,220,255,0.06) 65%, rgba(180,220,255,0.18) 100%);
            opacity: 0.18;
        }
        .v2-overlay-fog {
            background:
                radial-gradient(60% 40% at 20% 90%, rgba(158,196,255,0.12), transparent 70%),
                radial-gradient(58% 35% at 80% 92%, rgba(190,220,255,0.11), transparent 72%);
            animation: fogDrift 18s ease-in-out infinite alternate;
            opacity: 0.55;
        }
        .v2-overlay-haze {
            background: linear-gradient(180deg, rgba(128,188,255,0.03), transparent 32%, rgba(100,160,255,0.08) 100%);
            animation: neonBreath 4.2s ease-in-out infinite;
        }
        .v2-overlay-scan {
            background: linear-gradient(180deg, transparent 0%, rgba(57,213,255,0.08) 48%, transparent 100%);
            height: 32%;
            transform: translateY(-120%);
            animation: scanSweep 4.5s linear infinite;
            opacity: 0.35;
        }
        @keyframes fogDrift {
            0% { transform: translateX(-2%) translateY(0); }
            100% { transform: translateX(2%) translateY(-1.5%); }
        }
        @keyframes scanSweep {
            0% { transform: translateY(-120%); }
            100% { transform: translateY(420%); }
        }
        @keyframes neonBreath {
            0%,100% { opacity: 0.45; filter: saturate(1); }
            50% { opacity: 0.85; filter: saturate(1.2); }
        }
        body.fx-low #game-container::before,
        body.fx-low #game-container::after,
        body.fx-low .v2-overlay-rain,
        body.fx-low .v2-overlay-fog,
        body.fx-low .v2-overlay-scan,
        body.fx-low .v2-overlay-haze {
            animation: none !important;
            opacity: 0.12 !important;
        }
        body.fx-low .v2-overlay-rain,
        body.fx-low .v2-overlay-fog,
        body.fx-low .v2-overlay-scan {
            display: none;
        }
        /* Agent 状态条 */
        #agent-bar {
            display: flex; flex-wrap: wrap; gap: 3px; padding: 5px 8px;
            background: rgba(20,20,35,0.95); border-bottom: 1px solid var(--border);
        }
        .agent-chip {
            font-size: 10px; padding: 2px 7px; border-radius: 10px;
            color: #ddd; white-space: nowrap; display: flex; align-items: center; gap: 3px;
        }
        .agent-chip .dot {
            width: 5px; height: 5px; border-radius: 50%; display: inline-block;
        }
        .dot-idle { background: #555; }
        .dot-working { background: var(--green); animation: pulse 1.2s infinite; }
        .dot-error { background: var(--red); animation: pulse 0.6s infinite; }
        .dot-dead { background: #333; animation: pulse 2s infinite; }
        /* 日志面板（简洁可读） */
        #log-panel {
            position: relative;
            flex: 1; min-height: 0; overflow-y: auto; overflow-x: hidden; padding: 0;
            background: #0b1220;
        }
        #log-panel::-webkit-scrollbar { width: 4px; }
        #log-panel::-webkit-scrollbar-track { background: var(--bg-primary); }
        #log-panel::-webkit-scrollbar-thumb { background: #33415f; border-radius: 2px; }
        .log-section {
            border-bottom: 1px solid rgba(42,53,85,0.55); padding: 6px 10px;
            transition: background 0.2s, border-color 0.2s; overflow: hidden;
            background: rgba(255,255,255,0.01);
        }
        .log-section:hover { background: rgba(255,255,255,0.03); border-bottom-color: rgba(127,138,172,0.35); }
        .log-section.has-error { border-left: 2px solid var(--red); background: rgba(244,67,54,0.06); }
        .log-section.is-active { border-left: 2px solid var(--green); }
        .log-header {
            font-size: 11px; font-weight: 600; margin-bottom: 3px;
            display: flex; align-items: center; gap: 6px; min-width: 0; flex-wrap: wrap;
        }
        .log-header .a-name {
            color: var(--text-bright); min-width: 0; max-width: 140px;
            overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        }
        .log-header .a-model {
            color: #444; font-weight: 400; font-size: 9px; min-width: 0; max-width: 160px;
            overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        }
        .log-line {
            font-size: 9px; line-height: 1.5; color: #8da0ca;
            display: grid; grid-template-columns: 112px 14px minmax(0, 1fr); column-gap: 4px;
            align-items: start; font-family: 'Courier New', monospace;
        }
        .log-line .lt { color: #5f739c; font-size: 9px; }
        .log-line .lr { text-align: center; margin-top: 1px; }
        .log-line .lx {
            min-width: 0; white-space: pre-wrap;
            overflow-wrap: anywhere; word-break: break-word;
        }
        .log-line.r-user .lx { color: #7cb3f5; }
        .log-line.r-assistant .lx { color: #a8d8a8; }
        .log-line.r-tool .lx { color: #d4a574; }
        .log-line.r-error .lx { color: #f07070; }
        .log-line.r-system .lx { color: #b0b0d0; }

        /* ===== 任务完成/失败特效占位（V1） ===== */
        #street-fx-layer {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 80;
            overflow: hidden;
        }
        .street-fx {
            position: absolute;
            left: 50%;
            top: 16%;
            transform: translate(-50%, -50%);
            padding: 10px 18px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 1px;
            backdrop-filter: blur(2px);
            border: 1px solid transparent;
            opacity: 0;
            box-shadow: 0 8px 28px rgba(0,0,0,0.35);
        }
        .street-fx.complete {
            color: #dfffea;
            background: rgba(10, 36, 24, 0.68);
            border-color: rgba(104,255,159,0.45);
            text-shadow: 0 0 10px rgba(104,255,159,0.75);
            animation: fxPop 1.15s ease-out forwards;
        }
        .street-fx.failed {
            color: #ffe2e5;
            background: rgba(40, 12, 18, 0.7);
            border-color: rgba(255,95,112,0.5);
            text-shadow: 0 0 10px rgba(255,95,112,0.72);
            animation: fxPop 1.15s ease-out forwards;
        }
        @keyframes fxPop {
            0% { opacity: 0; transform: translate(-50%, -32%) scale(0.92); }
            20% { opacity: 1; transform: translate(-50%, -50%) scale(1.02); }
            75% { opacity: 1; }
            100% { opacity: 0; transform: translate(-50%, -62%) scale(1.03); }
        }

        /* ===== 日志增强 V1 ===== */
        #log-enhance-v1 {
            border-bottom: 1px solid var(--border);
            background: rgba(12, 18, 32, 0.96);
            padding: 8px 10px 7px;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .log-v1-row {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }
        .log-v1-overview {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 8px;
            width: 100%;
        }
        .log-v1-overview.compact {
            grid-template-columns: minmax(0, 1.7fr) minmax(0, 1fr);
        }
        .log-v1-stat {
            min-width: 0;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px;
            padding: 6px 8px;
            font-size: 10px;
            color: var(--text-dim);
        }
        .log-v1-stat .label {
            display: block;
            font-size: 9px;
            color: #7f7f95;
            margin-bottom: 2px;
        }
        .log-v1-stat .value {
            font-size: 14px;
            font-weight: 700;
            color: var(--text-bright);
            letter-spacing: 0.2px;
        }
        .log-v1-stat .value.warn { color: var(--yellow); }
        .log-v1-stat .value.err { color: var(--red); }
        .log-v1-stat .value.ok { color: var(--green); }

        #log-filter-chips {
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: nowrap;
            overflow-x: auto;
            padding-bottom: 2px;
        }
        #log-filter-chips::-webkit-scrollbar { height: 3px; }
        #log-filter-chips::-webkit-scrollbar-thumb { background: #303046; border-radius: 2px; }
        .log-chip {
            border: 1px solid #2f3045;
            background: rgba(255,255,255,0.03);
            color: #9191aa;
            border-radius: 999px;
            padding: 2px 10px;
            font-size: 10px;
            cursor: pointer;
            white-space: nowrap;
            transition: all 0.2s;
            user-select: none;
        }
        .log-chip:hover {
            color: #d8d8e8;
            border-color: #4d4e70;
            background: rgba(108,92,231,0.10);
        }
        .log-chip.active {
            color: #fff;
            border-color: var(--accent2);
            background: rgba(108,92,231,0.22);
            box-shadow: 0 0 0 1px rgba(108,92,231,0.18) inset;
        }
        .log-chip.danger.active {
            border-color: var(--red);
            background: rgba(244,67,54,0.18);
            box-shadow: 0 0 0 1px rgba(244,67,54,0.2) inset;
        }

        #log-actions {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }
        .log-action-btn {
            border: 1px solid #2b2c3d;
            background: rgba(255,255,255,0.03);
            color: #b4b4cb;
            border-radius: 6px;
            font-size: 10px;
            padding: 3px 8px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .log-action-btn:hover {
            color: #fff;
            border-color: #474866;
            background: rgba(255,255,255,0.08);
        }
        .log-action-btn.active {
            color: #fff;
            border-color: var(--accent);
            background: rgba(233,69,96,0.18);
        }
    </style>
    <style>
        /* ===== 右侧仪表盘（办公室视图） ===== */
        #office-right {
            flex: 0 0 clamp(312px, 23vw, 372px);
            min-width: 280px;
            display: flex;
            flex-direction: column;
            background: linear-gradient(180deg, rgba(16,21,37,0.96) 0%, rgba(11,14,24,0.98) 100%);
            border-left: 1px solid rgba(57,213,255,0.1);
            overflow-y: auto;
        }
        #office-right::-webkit-scrollbar { width: 4px; }
        #office-right::-webkit-scrollbar-thumb { background: #2f3344; border-radius: 2px; }
        .dash-header {
            position: sticky;
            top: 0;
            z-index: 4;
            padding: 12px 14px;
            font-size: 15px;
            font-weight: 700;
            color: var(--text-bright);
            border-bottom: 1px solid rgba(57,213,255,0.18);
            display: flex;
            align-items: baseline;
            gap: 8px;
            background: linear-gradient(135deg, rgba(233,69,96,0.12), rgba(108,92,231,0.12));
            backdrop-filter: blur(2px);
        }
        .dash-header .sub { font-size: 10px; color: #96a2c2; font-weight: 500; }
        .right-stack {
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding: 10px 12px 12px;
        }
        .right-card {
            background: rgba(17, 24, 40, 0.84);
            border: 1px solid rgba(118, 132, 170, 0.24);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 6px 18px rgba(0,0,0,0.22);
        }
        .right-card-head {
            padding: 9px 11px;
            border-bottom: 1px solid rgba(118, 132, 170, 0.2);
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            gap: 8px;
        }
        .right-card-title {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.35px;
            color: #dbe6ff;
        }
        .right-card-sub {
            font-size: 9px;
            color: #7e8db0;
            white-space: nowrap;
        }
        .right-card-body { padding: 10px 11px 11px; }
        .stat-row {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 8px;
            padding: 0;
        }
        .stat-card {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(136,151,191,0.28);
            border-radius: 10px;
            padding: 9px 8px;
            text-align: center;
            transition: transform 0.18s, box-shadow 0.18s, border-color 0.18s;
        }
        .stat-card:hover {
            transform: translateY(-1px);
            border-color: rgba(136,151,191,0.45);
            box-shadow: 0 4px 10px rgba(0,0,0,0.24);
        }
        .stat-card .sc-num { font-size: 18px; font-weight: 800; line-height: 1.2; }
        .stat-card .sc-label { font-size: 10px; color: #9da9c6; margin-top: 4px; }
        .stat-card .sc-bar { height: 3px; border-radius: 2px; margin-top: 7px; background: #21263a; }
        .stat-card .sc-bar-fill { height: 100%; border-radius: 2px; transition: width 0.5s; }
        .right-split {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 8px;
            margin-top: 8px;
        }
        .mini-kpi {
            border: 1px solid rgba(136,151,191,0.25);
            border-radius: 8px;
            padding: 7px 8px;
            background: rgba(255,255,255,0.02);
        }
        .mini-kpi .kpi-label { font-size: 9px; color: #8390ae; }
        .mini-kpi .kpi-value {
            margin-top: 2px;
            font-size: 13px;
            color: #f0f6ff;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .mini-kpi .kpi-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent2); box-shadow: 0 0 8px rgba(108,92,231,0.6); }

        .agent-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(74px, 1fr));
            gap: 8px;
            padding: 0;
