    function logV1ExportRecent(limit = 200) {
        const flat = [];
        for (const [aid, rows] of Object.entries(logV1State.rawLogs || {})) {
            const arr = Array.isArray(rows) ? rows : [];
            for (const row of arr) {
                const log = row && typeof row === 'object' ? row : {};
                flat.push({
                    aid,
                    ts: safeText(log.ts),
                    role: safeText(log.role),
                    stop: safeText(log.stop),
                    text: safeText(log.text),
                });
            }
        }
        flat.sort((a, b) => safeText(b.ts).localeCompare(safeText(a.ts)));
        const recent = flat.slice(0, limit);
        const lines = recent.map(item => {
            const t = utcToBJ(item.ts, true) || item.ts;
            const stop = item.stop ? `/${item.stop}` : '';
            return `[${t}] [${item.aid}] ${item.role}${stop} ${item.text}`;
        });

        const now = new Date();
        const pad = n => String(n).padStart(2, '0');
        const fname = `logs_recent_${limit}_${now.getFullYear()}${pad(now.getMonth()+1)}${pad(now.getDate())}_${pad(now.getHours())}${pad(now.getMinutes())}${pad(now.getSeconds())}.txt`;
        const blob = new Blob([lines.join('\n')], { type: 'text/plain;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = fname;
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(() => URL.revokeObjectURL(url), 5000);
    }

