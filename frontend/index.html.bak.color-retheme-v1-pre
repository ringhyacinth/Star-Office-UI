    const FETCH_INTERVAL = 3000, TASK_FETCH_INTERVAL = 15000;
    let lastFetch = 0, lastTaskFetch = 0;

    const STATES = {
        idle:        { name:'待命', area:'rest', color:'#555' },
        writing:     { name:'写码', area:'work', color:'#4caf50' },
