 54, 0.98), rgba(12, 20, 34, 0.98));\\n}\\n\\n.office-canvas {\\n  width: 100%;\\n  height: min(58vh, 560px);\\n  display: block;\\n}\\n\\n#v2-fx-overlays {\\n  pointer-events: none;\\n  position: absolute;\\n  inset: 0;\\n  background: radial-gradient(circle at 20% 24%, rgba(109, 209, 255, 0.24), transparent 42%),\\n    radial-gradient(circle at 74% 77%, rgba(102, 255, 173, 0.18), transparent 40%);\\n  mix-blend-mode: screen;\\n  opacity: 0.44;\\n}\\n\\n.canvas-hint {\\n  position: absolute;\\n  left: 12px;\\n  bottom: 10px;\\n  z-index: 2;\\n  font-size: 0.75rem;\\n  color: rgba(220, 239, 252, 0.95);\\n  background: rgba(8, 15, 26, 0.68);\\n  border: 1px solid rgba(122, 195, 255, 0.24);\\n  border-radius: 999px;\\n  padding: 4px 10px;\\n}\\n\\n#agent-bar {\\n  margin-top: 0.75rem;\\n  display: flex;\\n  flex-wrap: wrap;\\n  gap: 0.5rem;\\n}\\n\\n.agent-chip {\\n  border: 1px solid rgba(111, 186, 248, 0.34);\\n  border-radius: 999px;\\n  background: rgba(16, 26, 45, 0.74);\\n  color: #d7ecff;\\n  font-size: 0.74rem;\\n  line-height: 1;\\n  padding: 0.5rem 0.7rem;\\n  cursor: pointer;\\n  display: inline-flex;\\n  align-items: center;\\n  gap: 0.4rem;\\n  transition: all 0.16s ease;\\n}\\n\\n.agent-chip:hover {\\n  transform: translateY(-1px);\\n  background: rgba(23, 37, 61, 0.88);\\n}\\n\\n.agent-chip.selected {\\n  background: rgba(26, 40, 67, 0.94);\\n  color: #f2f8ff;\\n}\\n\\n.dot {\\n  width: 8px;\\n  height: 8px;\\n  border-radius: 999px;\\n  flex-shrink: 0;\\n}\\n\\n.status-working {\\n  background: #53f09f;\\n}\\n\\n.status-idle {\\n  background: #9db1c2;\\n}\\n\\n.status-error {\\n  background: #ff7b7b;\\n}\\n\\n.status-dead {\\n  background: #6f7782;\\n}\\n\\n.status-breathing {\\n  animation: breathingPulse 1.35s ease-in-out infinite;\\n}\\n\\n@keyframes breathingPulse {\\n  0% {\\n    transform: scale(0.85);\\n    opacity: 0.65;\\n  }\\n  50% {\\n    transform: scale(1.16);\\n    opacity: 1;\\n  }\\n  100% {\\n    transform: scale(0.85);\\n    opacity: 0.65;\\n  }\\n}\\n\\n#log-panel::-webkit-scrollbar,\\n#scroll-body::-webkit-scrollbar {\\n  width: 8px;\\n}\\n\\n#log-panel::-webkit-scrollbar-track,\\n#scroll-body::-webkit-scrollbar-track {\\n  background: rgba(10, 17, 29, 0.6);\\n  border-radius: 999px;\\n}\\n\\n#log-panel::-webkit-scrollbar-thumb,\\n#scroll-body::-webkit-scrollbar-thumb {\\n  background: linear-gradient(180deg, rgba(100, 179, 255, 0.5), rgba(84, 228, 177, 0.6));\\n  border-radius: 999px;\\n}\\n\\n.sr-only {\\n  position: absolute;\\n  width: 1px;\\n  height: 1px;\\n  padding: 0;\\n  margin: -1px;\\n  overflow: hidden;\\n  clip: rect(0, 0, 0, 0);\\n  white-space: nowrap;\\n  border: 0;\\n}\\n\\n@media (max-width: 1279px) {\\n  .office-canvas {\\n    height: min(48vh, 420px);\\n  }\\n}\\n\\n@media (max-width: 720px) {\\n  .stage-hud {\\n    top: 0.65rem;\\n    right: 0.65rem;\\n  }\\n}\\n\\n.api-strip {\\n  display: flex;\\n  flex-wrap: wrap;\\n  gap: 0.5rem;\\n  padding: 0.08rem 0.1rem;\\n}\\n\\n.api-error-banner {\\n  border: 1px solid rgba(251, 113, 133, 0.35);\\n  border-radius: 0.85rem;\\n  background: rgba(68, 17, 32, 0.45);\\n  padding: 0.75rem 0.85rem;\\n  color: #fecdd3;\\n  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);\\n}\\n\\n.api-error-banner ul {\\n  margin: 0.45rem 0 0;\\n  padding-left: 1rem;\\n  font-size: 0.82rem;\\n  line-height: 1.45;\\n}\\n\\n.api-error-title {\\n  margin: 0;\\n  display: inline-flex;\\n  align-items: center;\\n  gap: 0.4rem;\\n  font-size: 0.86rem;\\n  font-weight: 700;\\n}\\n\\n.api-empty-banner {\\n  display: grid;\\n  gap: 0.2rem;\\n  border: 1px dashed rgba(125, 190, 255, 0.36);\\n  border-radius: 0.85rem;\\n  background: rgba(16, 28, 45, 0.68);\\n  color: rgba(217, 236, 255, 0.9);\\n  padding: 0.72rem 0.82rem;\\n  font-size: 0.82rem;\\n}\\n\"\n__vite__updateStyle(__vite__id, __vite__css)\nimport.meta.hot.accept()\nimport.meta.hot.prune(() => __vite__removeStyle(__vite__id))"
